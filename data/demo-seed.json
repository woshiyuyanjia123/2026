  "overview": {
    "africa": {
      "title": {
        "zh": "非洲招标站：先看项目，再看要求",
        "en": "Africa Tender Board: Start with projects, then drill into requirements"
      },
      "text": {
        "zh": "这个站点面向非洲项目方或招标观察者，先从地区与项目列表入手，再逐步查看认证、交付与 lot 范围。",
        "en": "This site is designed for African buyers and observers: start with region and project discovery, then move into certifications, lead windows and lot scope."
      }
    },
    "china": {
      "title": {
        "zh": "中国供应站：先看能力，再看适配机会",
        "en": "China Supplier Network: Start with supplier capability, then see fit-for-tender opportunities"
      },
      "text": {
        "zh": "这个站点面向中国制造企业或投标支持人员，先看认证、产能、交期和非洲履约经验，再往深处看它适配哪些项目。",
        "en": "This site is for Chinese manufacturers and bid support teams: review certifications, capacity, lead time and African delivery experience before checking matched opportunities."
      }
    },
    "match": {
      "title": {
        "zh": "匹配模拟：先看规则，再看候选",
        "en": "Matching Simulator: Start with rules, then review ranked suppliers"
      },
      "text": {
        "zh": "这个页面承接招标与供应商之间的中间层，用五组规则输出可解释评分，并允许保存 shortlist。",
        "en": "This page sits between tenders and suppliers, using five weighted rules to produce explainable scores and a shortlist workflow."
      }
    }
  },
